# Crucible Service URLs — Minikube (Helm) deployment
# Used when CRUCIBLE_TARGET=minikube.
#
# Minikube routes everything through a single ingress host (default: `crucible`)
# behind a self-signed TLS cert. Add `127.0.0.1 crucible` to your hosts file and
# port-forward 443 → ingress controller (the minikube/crucible-deploy.sh script
# does this automatically).
#
# To target a different host (e.g. a remote cluster), override CRUCIBLE_HOST
# before running, or just edit this file.

CRUCIBLE_HOST=crucible

# Infrastructure
# (Aspire dashboard does not exist under minikube — leave blank.)
ASPIRE_DASHBOARD_URL=
KEYCLOAK_URL=https://crucible/keycloak
KEYCLOAK_REALM_URL=https://crucible/keycloak/realms/crucible

# Player
PLAYER_UI_URL=https://crucible/player
PLAYER_API_URL=https://crucible/player/api

# Player VM
PLAYERVM_UI_URL=https://crucible/vm
PLAYERVM_API_URL=https://crucible/vm/api

# Console
CONSOLE_UI_URL=https://crucible/console

# Caster
CASTER_UI_URL=https://crucible/caster
CASTER_API_URL=https://crucible/caster/api

# Alloy
ALLOY_UI_URL=https://crucible/alloy
ALLOY_API_URL=https://crucible/alloy/api

# TopoMojo
TOPOMOJO_UI_URL=https://crucible/topomojo
TOPOMOJO_API_URL=https://crucible/topomojo/api

# Steamfitter
STEAMFITTER_UI_URL=https://crucible/steamfitter
STEAMFITTER_API_URL=https://crucible/steamfitter/api

# CITE
CITE_UI_URL=https://crucible/cite
CITE_API_URL=https://crucible/cite/api

# Gallery
GALLERY_UI_URL=https://crucible/gallery
GALLERY_API_URL=https://crucible/gallery/api

# Blueprint
BLUEPRINT_UI_URL=https://crucible/blueprint
BLUEPRINT_API_URL=https://crucible/blueprint/api

# Gameboard
GAMEBOARD_UI_URL=https://crucible/gameboard
GAMEBOARD_API_URL=https://crucible/gameboard/api

# Other Services
MOODLE_URL=https://crucible
# LRsql and MISP are not part of the default minikube deployment.
LRSQL_URL=
MISP_URL=
